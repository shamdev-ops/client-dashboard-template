VITE_SUPABASE_PROJECT_ID="your-project-id"
# Must be Supabase Project Settings → API → "anon" "public" key (JWT, starts with eyJ).
# Do not use Lovable/other "sb_publishable_…" keys here — Edge Functions will fail to invoke.
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."
# Optional alias (same value as anon JWT); scripts like set-braze-rest-url.ts use this name.
# VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# New signups: turn on email confirmation in Supabase → Authentication → Providers → Email (Confirm email).
# Apply pending DB migrations so new profiles start with is_approved = false until an admin approves (first user stays auto-approved admin).

# If platform connect or onboarding upsert fails with RLS, ensure the user row is approved, e.g. in SQL Editor:
#   UPDATE public.profiles SET is_approved = true WHERE id = 'YOUR_AUTH_USER_UUID';
# "Failed to send a request to the Edge Function" means the browser could not reach Functions (wrong URL, function not deployed, or network) — not an is_approved issue.

# CRM Copilot (ops-chat Edge Function) — Anthropic only; set on Supabase, NOT in Vite:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   Optional: ANTHROPIC_MODEL=claude-3-5-sonnet-latest
